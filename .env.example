# Copy the variables below into your Vercel project's Environment Variables
# (Project Settings -> Environment Variables). Do not commit a real .env file.

# Random long string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=

# Keep False in production.
DEBUG=False

# Comma-separated extra hostnames, if any (Vercel's *.vercel.app is already allowed).
ALLOWED_HOSTS=

# Postgres connection string from your database provider (e.g. Neon, Supabase).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# From your Cloudinary dashboard: Account Details -> API Environment variable.
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
